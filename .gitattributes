# Playwright visual-regression baselines are binary PNGs that don't compress
# well in normal git packfiles and bloat the working clone on every CSS tweak
# that triggers a re-baseline. Store them in Git LFS so they live in a
# separate blob store instead of the main packfile history.
#
# Pattern catches every spec's `-snapshots/` folder (Playwright's default
# naming) plus any standalone __screenshots__ directory.
apps/ng-bootstrap-demo-e2e/**/*-snapshots/*.png filter=lfs diff=lfs merge=lfs -text
apps/ng-bootstrap-demo-e2e/**/__screenshots__/**/*.png filter=lfs diff=lfs merge=lfs -text

# Line endings: force LF for text files so cross-platform commits don't
# produce phantom diffs and so the CEM-generated `custom-elements.json`
# stays stable (its `description` fields embed JSDoc text from .ts source
# files; if some sources are CRLF and others LF, the JSON ends up with
# mixed `\r\n` and `\n` escape sequences inside string values).
*               text=auto eol=lf

# Windows-shell files MUST keep CRLF or cmd.exe trips.
*.bat           text eol=crlf
*.cmd           text eol=crlf
*.ps1           text eol=crlf

# Common binary types — explicit so `text=auto` doesn't misdetect.
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.webp          binary
*.ico           binary
*.woff          binary
*.woff2         binary
*.ttf           binary
*.eot           binary
*.pdf           binary
*.zip           binary
*.gz            binary
