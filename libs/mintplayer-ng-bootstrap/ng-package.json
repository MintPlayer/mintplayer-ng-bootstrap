{
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "../../dist/libs/mintplayer-ng-bootstrap",
  "lib": {
    "entryFile": "src/index.ts",
    "sass": {
      "silenceDeprecations": [
        "import",
        "global-builtin",
        "color-functions",
        "if-function",
        "legacy-js-api"
      ]
    }
  },
  "assets": [
    "./src/assets/**",
    "./src/styles/**",
    "./_bootstrap.scss"
  ]
}