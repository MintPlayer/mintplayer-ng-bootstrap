{
  "name": "mintplayer-ng-bootstrap",
  "$schema": "..\\..\\node_modules\\nx\\schemas\\project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/mintplayer-ng-bootstrap/src",
  "prefix": "bs",
  "tags": [],
  "targets": {
    "codegen-wc": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/**/web-components/*.element.template.ts",
        "{projectRoot}/**/*.styles.ts"
      ],
      "inputs": [
        "{projectRoot}/**/web-components/*.element.html",
        "{projectRoot}/**/web-components/*.element.scss",
        "{projectRoot}/**/*.styles.scss",
        "{workspaceRoot}/tools/scripts/build-web-components.mjs"
      ],
      "cache": true,
      "options": {
        "command": "node tools/scripts/build-web-components.mjs libs/mintplayer-ng-bootstrap"
      }
    },
    "build": {
      "executor": "@nx/angular:package",
      "dependsOn": ["^build", "codegen-wc"],
      "outputs": ["{workspaceRoot}/dist/libs/mintplayer-ng-bootstrap"],
      "options": {
        "tsConfig": "libs/mintplayer-ng-bootstrap/tsconfig.lib.json",
        "project": "libs/mintplayer-ng-bootstrap/ng-package.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/mintplayer-ng-bootstrap/tsconfig.lib.prod.json"
        },
        "development": {
          "tsConfig": "libs/mintplayer-ng-bootstrap/tsconfig.lib.json"
        }
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@analogjs/vitest-angular:test",
      "outputs": ["{workspaceRoot}/coverage/libs/mintplayer-ng-bootstrap"],
      "options": {
        "configFile": "vitest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
