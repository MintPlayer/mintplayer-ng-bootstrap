# See http://help.github.com/ignore-files/ for more about ignoring files.

# compiled output
/dist
/tmp
/out-tsc

# dependencies
**/node_modules
/.nx

# IDEs and editors
/.vs
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.angular

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Playwright MCP local artefacts (screenshots, traces)
.playwright-mcp/

# Environment variables (generated on VPS at deploy time)
.env

# Generated web-component artefacts (built from sibling .html / .scss)
libs/**/web-components/*.element.template.ts
libs/**/*.styles.ts