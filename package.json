{
  "name": "mintplayer-ng-bootstrap",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "ng": "nx",
    "nx": "nx",
    "postinstall": "node ./decorate-angular-cli.js && nx run-many --target=codegen-wc",
    "codegen-wc": "nx run mintplayer-ng-bootstrap:codegen-wc",
    "codegen-wc:watch": "node tools/scripts/build-web-components.mjs libs/mintplayer-ng-bootstrap --watch",
    "start": "concurrently -k -n codegen,serve -c blue,green \"npm:codegen-wc:watch\" \"nx serve\"",
    "start:network": "concurrently -k -n codegen,serve -c blue,green \"npm:codegen-wc:watch\" \"nx serve --configuration=network\"",
    "build": "nx build",
    "build:wba": "nx build --stats-json",
    "analyze:wba": "webpack-bundle-analyzer dist/apps/ng-bootstrap-demo/stats.json",
    "build:sme": "nx build --source-map",
    "analyze:sme": "source-map-explorer dist/apps/ng-bootstrap-demo/browser/browser/*",
    "test": "nx run-many --target=test --all --parallel",
    "test:watch": "vitest",
    "dev:ssr": "nx serve ng-bootstrap-demo",
    "check:ribbon-size": "node tools/scripts/check-ribbon-bundle-size.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~21.2.9",
    "@angular/cdk": "~21.2.9",
    "@angular/common": "~21.2.9",
    "@angular/compiler": "~21.2.9",
    "@angular/core": "~21.2.9",
    "@angular/forms": "~21.2.9",
    "@angular/platform-browser": "~21.2.9",
    "@angular/platform-browser-dynamic": "~21.2.9",
    "@angular/platform-server": "~21.2.9",
    "@angular/router": "~21.2.9",
    "@angular/ssr": "~21.2.9",
    "@lit/context": "^1.1.6",
    "@nx/angular": "22.7.2",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "~1.11.3",
    "express": "^5.1.0",
    "lit": "^3.3.2",
    "ngx-highlightjs": "~14.0.0",
    "ts-dedent": "^2.2.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/vitest-angular": "^2.2.3",
    "@angular-devkit/build-angular": "~21.2.9",
    "@angular-devkit/core": "~21.2.9",
    "@angular-devkit/schematics": "~21.2.9",
    "@angular-eslint/eslint-plugin": "~21.3.1",
    "@angular-eslint/eslint-plugin-template": "~21.3.1",
    "@angular-eslint/template-parser": "~21.3.1",
    "@angular/build": "~21.2.9",
    "@angular/cli": "~21.2.9",
    "@angular/compiler-cli": "~21.2.9",
    "@angular/language-service": "~21.2.9",
    "@axe-core/playwright": "^4.11.3",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@nx/eslint": "22.7.2",
    "@nx/eslint-plugin": "22.7.2",
    "@nx/js": "22.7.2",
    "@nx/playwright": "22.7.2",
    "@nx/vite": "22.7.2",
    "@nx/vitest": "22.7.2",
    "@nx/web": "22.7.2",
    "@nx/workspace": "22.7.2",
    "@playwright/test": "^1.59.1",
    "@schematics/angular": "21.2.9",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.33",
    "@swc/helpers": "~0.5.18",
    "@types/express": "^5.0.1",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "7.16.0",
    "@typescript-eslint/parser": "7.16.0",
    "@typescript-eslint/utils": "^7.16.0",
    "@vitest/coverage-v8": "^4.0.16",
    "ajv": "^8.0.0",
    "autoprefixer": "^10.4.0",
    "browser-sync": "^3.0.0",
    "chokidar": "^5.0.0",
    "concurrently": "^9.1.2",
    "eslint": "8.57.0",
    "eslint-config-prettier": "10.0.0",
    "jiti": "2.4.2",
    "jsdom": "^27.2.0",
    "jsonc-eslint-parser": "^2.1.0",
    "ng-mocks": "^14.15.2",
    "ng-packagr": "~21.2.3",
    "nx": "22.7.2",
    "postcss": "^8.4.5",
    "postcss-import": "^14.1.0",
    "postcss-preset-env": "^7.5.0",
    "postcss-url": "^10.1.3",
    "prettier": "^2.6.2",
    "resize-observer-polyfill": "^1.5.1",
    "sass": "^1.99.0",
    "source-map-explorer": "^2.5.3",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vite": "^6.4.1",
    "vite-plugin-dts": "~4.5.0",
    "vitest": "^4.0.16",
    "webpack-bundle-analyzer": "~4.9.0"
  }
}
