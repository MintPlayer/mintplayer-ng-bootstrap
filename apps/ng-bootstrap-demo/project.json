{
  "name": "ng-bootstrap-demo",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/ng-bootstrap-demo/src",
  "prefix": "demo",
  "tags": [],
  "generators": {
    "@schematics/angular:component": {
      "style": "scss"
    }
  },
  "targets": {
    "build": {
      "//silenceDeprecations": "stylePreprocessorOptions.sass.silenceDeprecations below is needed only because Bootstrap 5.3.x's SCSS triggers these Sass 3.0 deprecation IDs (twbs/bootstrap#40849, #40962). Upstream's fix PR (twbs/bootstrap#41112) was closed without merging; the cleanup landed only on v6-dev as part of a full rewrite. Drop the silenceDeprecations array here AND in libs/mintplayer-ng-bootstrap/ng-package.json (lib.sass.silenceDeprecations) when bumping the bootstrap peer dep to v6.",
      "executor": "@angular-devkit/build-angular:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/ng-bootstrap-demo/browser",
        "index": "apps/ng-bootstrap-demo/src/index.html",
        "browser": "apps/ng-bootstrap-demo/src/main.ts",
        "server": "apps/ng-bootstrap-demo/src/main.server.ts",
        "outputMode": "server",
        "ssr": {
          "entry": "apps/ng-bootstrap-demo/server.ts"
        },
        "tsConfig": "apps/ng-bootstrap-demo/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          "apps/ng-bootstrap-demo/src/favicon.ico",
          "apps/ng-bootstrap-demo/src/favicon.svg",
          "apps/ng-bootstrap-demo/src/assets",
          "apps/ng-bootstrap-demo/src/web.config",
          "apps/ng-bootstrap-demo/src/nginx.conf"
        ],
        "styles": [
          "apps/ng-bootstrap-demo/src/styles.scss",
          {
            "input": "libs/mintplayer-ng-bootstrap/src/styles/ngx-highlight-themes/a11y-dark.scss",
            "inject": false,
            "bundleName": "a11y-dark"
          }
        ],
        "scripts": [],
        "stylePreprocessorOptions": {
          "includePaths": [
            ".",
            "node_modules"
          ],
          "sass": {
            "silenceDeprecations": [
              "import",
              "global-builtin",
              "color-functions",
              "if-function",
              "legacy-js-api"
            ]
          }
        },
        "loader": {
          ".svg": "text"
        }
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "25kb",
              "maximumError": "100kb"
            }
          ],
          "fileReplacements": [
            {
              "replace": "apps/ng-bootstrap-demo/src/environments/environment.ts",
              "with": "apps/ng-bootstrap-demo/src/environments/environment.prod.ts"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "options": {
        "proxyConfig": "apps/ng-bootstrap-demo/proxy.conf.json",
        "open": true
      },
      "configurations": {
        "production": {
          "buildTarget": "ng-bootstrap-demo:build:production"
        },
        "development": {
          "buildTarget": "ng-bootstrap-demo:build:development"
        },
        "network": {
          "buildTarget": "ng-bootstrap-demo:build:development",
          "host": "0.0.0.0",
          "allowedHosts": ["localhost"]
        }
      },
      "defaultConfiguration": "development",
      "continuous": true,
      "dependsOn": [{ "projects": ["api"], "target": "serve" }]
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "ng-bootstrap-demo:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@analogjs/vitest-angular:test",
      "outputs": ["{workspaceRoot}/coverage/apps/ng-bootstrap-demo"],
      "options": {
        "configFile": "vitest.config.ts"
      }
    }
  }
}
