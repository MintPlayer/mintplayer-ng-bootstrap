{
  "name": "vue-bootstrap-demo",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/vue-bootstrap-demo/src",
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/vue-bootstrap-demo/browser",
        "skipTypeCheck": true
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },
    "build-ssr": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/apps/vue-bootstrap-demo/server"
      ],
      "dependsOn": [
        "^build"
      ],
      "options": {
        "command": "npx vite build --config apps/vue-bootstrap-demo/vite.config.mts --ssr src/entry-server.ts"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "continuous": true,
      "dependsOn": [
        { "projects": ["api"], "target": "serve" },
        { "projects": ["mintplayer-web-components"], "target": "codegen-wc" },
        { "projects": ["mintplayer-web-components"], "target": "codegen-wc-watch" }
      ],
      "options": {
        "command": "node apps/vue-bootstrap-demo/server.mjs"
      }
    },
    "preview": {
      "dependsOn": [
        "build"
      ],
      "executor": "@nx/vite:preview-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "vue-bootstrap-demo:build"
      },
      "configurations": {
        "development": {
          "buildTarget": "vue-bootstrap-demo:build:development"
        },
        "production": {
          "buildTarget": "vue-bootstrap-demo:build:production"
        }
      }
    }
  }
}
